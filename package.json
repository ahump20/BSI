{
  "name": "college-baseball-tracker",
  "version": "1.0.0",
  "type": "module",
  "description": "Mobile-first college baseball live tracker with full box scores",
  "scripts": {
    "dev": "next dev",
    "dev:vite": "vite",
    "build:lib": "tsc",
    "copy:web-vitals": "cp node_modules/web-vitals/dist/web-vitals.attribution.js public/js/web-vitals.min.js",
    "build": "bash scripts/build-safe.sh",
    "build:local": "next build && node scripts/generate-sitemap.mjs",
    "build:vite": "npm run copy:web-vitals && vite build",
    "preview": "vite preview",
    "deploy:stage": "bash scripts/stage-pages-deploy.sh",
    "deploy": "npm run build && npm run deploy:stage && wrangler pages deploy /var/tmp/bsi-deploy-out --project-name blazesportsintel --branch main",
    "predeploy:production": "npm run gate:cbb",
    "deploy:production": "npm run build && npm run deploy:stage && wrangler pages deploy /var/tmp/bsi-deploy-out --project-name blazesportsintel --branch main --commit-dirty=true && npm run health",
    "deploy:preview": "npm run build && npm run deploy:stage && wrangler pages deploy /var/tmp/bsi-deploy-out --project-name blazesportsintel --branch preview && npm run health:preview",
    "deploy:worker": "wrangler deploy --config workers/wrangler.toml --env production",
    "deploy:worker:production": "wrangler deploy --config workers/wrangler.toml --env production",
    "deploy:live-scores": "wrangler deploy --config workers/bsi-live-scores/wrangler.toml",
    "deploy:daily-digest": "wrangler deploy --config workers/bsi-college-baseball-daily/wrangler.toml",
    "deploy:hybrid": "npm run deploy:production && npm run deploy:worker:production",
    "dev:worker": "wrangler dev --config workers/wrangler.toml",
    "dev:hybrid": "npm run dev & npm run dev:worker",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:api": "vitest run tests/api/",
    "test:workers": "vitest run tests/workers/",
    "test:all": "vitest run",
    "test:routes": "playwright test tests/routes/",
    "test:a11y": "playwright test --config=playwright.config.ts",
    "test:a11y:ui": "playwright test --config=playwright.config.ts --ui",
    "test:a11y:report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "typecheck:strict": "tsc --project tsconfig.strict.json",
    "deploy:show-dd-sync": "wrangler deploy --config workers/bsi-show-dd-sync/wrangler.toml",
    "typecheck:workers": "for d in workers/blaze-field-do workers/blaze-field-site workers/bsi-savant-compute workers/bsi-cbb-analytics workers/bsi-cbb-ingest workers/bsi-college-baseball-daily workers/bsi-live-scores workers/bsi-show-dd-sync workers/bsi-portal-sync workers/sportradar-ingest workers/synthetic-monitor workers/error-tracker workers/bsi-analytics-events workers/bsi-intelligence-stream workers/bsi-social-intel workers/college-baseball-mcp workers/mini-games-api; do echo \"Checking $d...\" && tsc --noEmit -p $d/tsconfig.json || exit 1; done && echo 'All workers pass.'",
    "lint": "eslint app lib components tests scripts --ext .js,.jsx,.ts,.tsx,.mjs --ignore-pattern 'node_modules/**'",
    "lint:fix": "eslint app lib components tests scripts --ext .js,.jsx,.ts,.tsx,.mjs --fix --ignore-pattern 'node_modules/**'",
    "format": "prettier --check \"app/**/*.{js,jsx,ts,tsx,json,css,md}\" \"lib/**/*.{js,jsx,ts,tsx,json,css,md}\" \"hooks/**/*.{js,jsx,ts,tsx,json,css,md}\" \"components/**/*.{js,jsx,ts,tsx,json,css,md}\" \"workers/**/*.{js,jsx,ts,tsx,json,css,md}\" \"tests/**/*.{js,jsx,ts,tsx,json,css,md}\" \"scripts/**/*.{js,mjs,ts,tsx,sh}\"",
    "format:fix": "prettier --write \"app/**/*.{js,jsx,ts,tsx,json,css,md}\" \"lib/**/*.{js,jsx,ts,tsx,json,css,md}\" \"hooks/**/*.{js,jsx,ts,tsx,json,css,md}\" \"components/**/*.{js,jsx,ts,tsx,json,css,md}\" \"workers/**/*.{js,jsx,ts,tsx,json,css,md}\" \"tests/**/*.{js,jsx,ts,tsx,json,css,md}\" \"scripts/**/*.{js,mjs,ts,tsx,sh}\"",
    "health": "bash scripts/post-deploy-smoke.sh",
    "health:preview": "BSI_BASE_URL=https://preview.blazesportsintel.pages.dev bash scripts/post-deploy-smoke.sh",
    "perf:check": "node scripts/verify-sportsdataio-smoke.mjs",
    "data:freshness": "node scripts/check-data-freshness.js",
    "cache:warm": "node scripts/warm-cache.js",
    "prepare": "husky",
    "db:migrate:production": "wrangler d1 execute blazesports-historical --remote --file=schema/003_migration_drop_and_recreate.sql",
    "db:seed:production": "wrangler d1 execute blazesports-historical --remote --file=scripts/insert-test-teams-fixed.sql",
    "build:arcade": "cd games/blitz && npm run build && cd ../hotdog-dash && npm run build && cd ../.. && npm run arcade:copy",
    "arcade:copy": "echo 'Games are self-hosted in public/games/ -- no copy needed'",
    "deploy:arcade": "echo 'Games deploy with Pages -- use deploy:pages'",
    "deploy:arcade-api": "wrangler deploy --config workers/mini-games-api/wrangler.toml",
    "deploy:safe": "bash scripts/pre-deploy-check.sh && npm run deploy:stage && wrangler pages deploy /var/tmp/bsi-deploy-out --project-name blazesportsintel --branch main --commit-dirty=true",
    "deploy:all": "npm run deploy:safe && npm run deploy:worker:production",
    "sportsdataio:dry-run": "node scripts/sportsdataio-dry-run.mjs",
    "bundle:build": "tsx tools/build-ncaa-baseball-daily-bundle.ts",
    "bundle:upload": "tsx tools/build-ncaa-baseball-daily-bundle.ts --upload",
    "deploy:guarded": "node scripts/guarded-deploy.mjs",
    "release:preview": "node scripts/guarded-deploy.mjs --preview-only",
    "smoke:homepage": "npx playwright test tests/smoke/homepage.spec.ts --config=playwright.smoke.config.ts --project=chromium",
    "smoke:release": "npx playwright test tests/smoke/homepage.spec.ts tests/smoke/public-layout.spec.ts tests/smoke/scores-integrity.spec.ts tests/smoke/mobile-overflow.spec.ts --config=playwright.smoke.config.ts --project=chromium",
    "gate:cbb": "npx playwright test tests/routes/college-baseball-critical.spec.ts tests/routes/college-baseball-api.spec.ts tests/routes/rankings.spec.ts --config=playwright.config.ts --project=chromium",
    "gate:release": "npm run smoke:release && npm run gate:cbb",
    "smoke:cross-property": "node scripts/cross-property-smoke.mjs",
    "smoke:predeploy": "npx playwright test tests/smoke/homepage.spec.ts --config=playwright.smoke.config.ts --project=chromium",
    "release:guarded": "node scripts/release-guarded.mjs",
    "rollback:pages": "node scripts/pages-rollback.mjs",
    "rollback:pages:list": "node scripts/pages-rollback.mjs --list",
    "scan:secrets": "npx --no-install secretlint --secretlintrc .secretlintrc.json --secretlintignore .secretlintignore .",
    "scan:secrets:staged": "node scripts/secretlint-staged.mjs"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.32",
    "@stripe/react-stripe-js": "^3.10.0",
    "@stripe/stripe-js": "^5.10.0",
    "@tanstack/react-query": "^5.90.20",
    "@types/d3": "^7.4.3",
    "claude": "^0.1.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "framer-motion": "^12.29.2",
    "hono": "^4.11.9",
    "lucide-react": "^0.546.0",
    "luxon": "^3.7.2",
    "next": "^16.1.6",
    "posthog-js": "^1.345.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.7.0",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@cloudflare/workers-types": "^4.20260131.0",
    "@playwright/test": "^1.58.2",
    "@secretlint/secretlint-rule-preset-recommend": "^11.3.1",
    "@testing-library/react": "^16.3.2",
    "@types/luxon": "^3.7.1",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.24",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^14.0.0",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "playwright": "^1.58.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "secretlint": "^11.3.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "wrangler": "^4.35.0"
  },
  "optionalDependencies": {
    "@cloudflare/workerd-darwin-arm64": "^1.20260131.0"
  },
  "overrides": {
    "minimatch": ">=3.1.5"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0",
      "qs": ">=6.14.2",
      "form-data": ">=4.0.1",
      "tough-cookie": ">=4.1.3",
      "rollup": ">=4.59.0"
    },
    "pnpm": {
      "overrides": {
        "rollup": ">=4.59.0"
      }
    }
  },
  "main": "vite.config.js",
  "directories": {
    "doc": "docs",
    "lib": "lib",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahump20/BSI.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ahump20/BSI/issues"
  },
  "homepage": "https://github.com/ahump20/BSI#readme"
}
