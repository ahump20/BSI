{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "BSI Site (Next.js)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "BSI Worker (Wrangler)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:worker"],
      "port": 8787
    },
    {
      "name": "BSI Mobile (Expo)",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["expo", "start", "--ios"],
      "port": 8081
    }
  ]
}
